{
  "name": "cdx-sessions",
  "version": "0.1.0",
  "description": "Interactive CLI for finding and resuming Codex sessions across projects.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "codex",
    "cli",
    "tui",
    "sessions",
    "terminal",
    "ink"
  ],
  "bin": {
    "cdx-sessions": "dist/cli.js"
  },
  "files": [
    ".gitignore",
    "dist"
  ],
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json && node scripts/chmod-bin.mjs",
    "dev": "tsx src/cli.tsx",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "ink": "^7.0.0",
    "react": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.16"
  }
}
